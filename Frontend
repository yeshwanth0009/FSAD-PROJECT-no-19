<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Samvidhan Connect</title>

<!-- Google Font -->
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins', sans-serif;
}

body{
    background: linear-gradient(135deg,#ff9933,#ffffff,#138808);
}

/* HEADER */
header{
    background: rgba(0,0,0,0.7);
    color:white;
    padding:20px 0;
    text-align:center;
}

header h1{
    font-size:40px;
    letter-spacing:2px;
}

header p{
    font-size:18px;
    margin-top:5px;
    color:#f1f1f1;
}

/* NAVBAR */
nav{
    background:#000080;
    display:flex;
    justify-content:center;
    padding:12px;
}

nav a{
    color:white;
    text-decoration:none;
    margin:0 20px;
    font-weight:600;
    transition:0.3s;
}

nav a:hover{
    color:#ff9933;
}

/* HERO SECTION */
.hero{
    text-align:center;
    padding:80px 20px;
    color:#000;
}

.hero h2{
    font-size:38px;
    margin-bottom:20px;
}

.hero p{
    font-size:18px;
    margin-bottom:30px;
}

.hero button{
    padding:12px 30px;
    font-size:16px;
    border:none;
    border-radius:30px;
    background:#000080;
    color:white;
    cursor:pointer;
    transition:0.3s;
}

.hero button:hover{
    background:#ff9933;
}

/* ROLE CARDS */
.roles{
    display:flex;
    justify-content:center;
    flex-wrap:wrap;
    padding:40px 20px;
    gap:30px;
}

.card{
    background:white;
    width:250px;
    padding:25px;
    border-radius:15px;
    text-align:center;
    box-shadow:0 8px 20px rgba(0,0,0,0.3);
    transition:0.4s;
}

.card:hover{
    transform:translateY(-10px);
}

.card h3{
    margin-bottom:15px;
    color:#000080;
}

.card p{
    font-size:14px;
}

/* FOOTER */
footer{
    background:#000080;
    color:white;
    text-align:center;
    padding:15px;
    margin-top:40px;
}

/* RESPONSIVE */
@media(max-width:768px){
    .roles{
        flex-direction:column;
        align-items:center;
    }
}

</style>
</head>

<body>

<header>
    <h1>🇮🇳 Samvidhan Connect</h1>
    <p>Empowering Citizens Through Constitutional Awareness</p>
</header>

<nav>
    <a href="#">Home</a>
    <a href="#">Preamble</a>
    <a href="#">Fundamental Rights</a>
    <a href="#">Duties</a>
    <a href="#">Quiz</a>
    <a href="#">Login</a>
</nav>

<section class="hero">
    <h2>Know Your Constitution</h2>
    <p>Learn about your rights, duties and the framework of the Indian Constitution in an interactive way.</p>
    <button onclick="startLearning()">Start Learning</button>
</section>

<section class="roles">
    <div class="card">
        <h3>Admin</h3>
        <p>Manage platform content, verify information and oversee user roles.</p>
    </div>

    <div class="card">
        <h3>Educator</h3>
        <p>Create structured educational content and conduct interactive sessions.</p>
    </div>

    <div class="card">
        <h3>Citizen</h3>
        <p>Explore constitutional content, participate in discussions and quizzes.</p>
    </div>

    <div class="card">
        <h3>Legal Expert</h3>
        <p>Provide legal insights, update amendments and guide citizens.</p>
    </div>
</section>

<footer>
    © 2026 Samvidhan Connect | Made with Pride in India 🇮🇳
</footer>

<script>
function startLearning(){
    alert("Welcome to Samvidhan Connect 🇮🇳\nLet's begin your constitutional journey!");
}
</script>

</body>
</html>
